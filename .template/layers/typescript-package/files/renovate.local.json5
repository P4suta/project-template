{
  // ローカル lookup 専用(scripts/renovate-local.sh が読む)。PR ボットは
  // Dependabot(.github/dependabot.yml)。デフォルト名(renovate.json)を避けるのは、
  // 将来 Renovate ボットを有効化しても自動検出させず Dependabot と混線させないため。
  //
  // 全マネージャ(npm / dockerfile / github-actions / mise / devcontainer)は
  // デフォルトで有効。lookup なので広く拾うほどよい。
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  // dependabot.yml の ignore と parity を取りたい場合はここに追記:
  //   packageRules: [{ matchPackageNames: ["..."], enabled: false }],
  packageRules: [],
}
