set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set dotenv-load := false

DEV := "docker compose run --rm dev"

default:
    @just --list --unsorted

# ---------------------------------------------------------------------------
# Bootstrap
# ---------------------------------------------------------------------------

bootstrap:
    docker compose build dev
    {{DEV}} npm ci
    just hooks

hooks:
    {{DEV}} lefthook install

hooks-uninstall:
    {{DEV}} lefthook uninstall

# Open an interactive shell in the dev container.
sh:
    {{DEV}} bash

# ---------------------------------------------------------------------------
# Build / run
# ---------------------------------------------------------------------------

build:
    {{DEV}} npm run build

# ---------------------------------------------------------------------------
# Lint / format
# ---------------------------------------------------------------------------

fmt:
    {{DEV}} npm run fmt

fmt-check:
    {{DEV}} npm run fmt:check

lint-biome:
    {{DEV}} npm run lint

typos:
    {{DEV}} typos

actionlint:
    {{DEV}} actionlint || true

yamllint:
    {{DEV}} yamllint .

markdownlint:
    {{DEV}} markdownlint-cli2 "**/*.md" "#node_modules" "#dist" "#coverage"

lint: fmt-check lint-biome typos

# ---------------------------------------------------------------------------
# Test, coverage
# ---------------------------------------------------------------------------

test:
    {{DEV}} npm test

coverage:
    {{DEV}} npm run coverage

# ---------------------------------------------------------------------------
# Dependencies — local freshness lookup
# ---------------------------------------------------------------------------

# Renovate --platform=local(dryRun=lookup)で全エコシステム横断の「古さ」を
# ローカル確認。PR は Dependabot に任せたまま、push を待たず手元で気づくための
# read-only な lookup。dev コンテナではなくホスト側で動く(lookup は manifest を
# 読み datasource を引くだけ。scripts/renovate-local.sh 参照)。
renovate-local:
    bash scripts/renovate-local.sh

# ---------------------------------------------------------------------------
# Aggregate
# ---------------------------------------------------------------------------

ci: lint test coverage build
